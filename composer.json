{
    "name": "pawpayments/sdk",
    "description": "PHP SDK for PawPayments API v2",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "PawPayments\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PawPayments\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
